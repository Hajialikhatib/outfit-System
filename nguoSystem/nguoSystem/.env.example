# ==========================================
# DJANGO SETTINGS
# ==========================================

# Secret key for Django (generate a new one for production!)
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode - ALWAYS False in production!
DEBUG=False

# Allowed hosts (comma separated list of domain names)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Environment (development or production)
ENVIRONMENT=production

# ==========================================
# DATABASE SETTINGS (MySQL)
# ==========================================

DB_NAME=nguo_system
DB_USER=nguo_user
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=3306

# Optional: Unix socket (comment out if using TCP)
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# Optional: SSL configuration (comment out if not using SSL)
# DB_SSL_CA=/etc/mysql/ca-cert.pem

# ==========================================
# CORS SETTINGS
# ==========================================

# Your production frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# STATIC & MEDIA FILES
# ==========================================

# These are automatically set in settings.py, but can be overridden
# STATIC_ROOT=/path/to/staticfiles
# MEDIA_ROOT=/path/to/media

# ==========================================
# EMAIL SETTINGS (Optional)
# ==========================================

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
